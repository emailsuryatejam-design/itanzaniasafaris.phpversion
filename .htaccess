RewriteEngine On

# Force HTTPS
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Remove www
RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [L,R=301]

# German language rewrites
RewriteRule ^de/?$ index.php?lang=de [L,QSA]
RewriteRule ^de/safaris/?$ safaris.php?lang=de [L,QSA]
RewriteRule ^de/kilimanjaro/?$ kilimanjaro.php?lang=de [L,QSA]
RewriteRule ^de/sansibar/?$ zanzibar.php?lang=de [L,QSA]
RewriteRule ^de/unterkuenfte/?$ accommodations.php?lang=de [L,QSA]
RewriteRule ^de/ueber-uns/?$ about.php?lang=de [L,QSA]
RewriteRule ^de/blog/?$ blog.php?lang=de [L,QSA]
RewriteRule ^de/blog-post/?$ blog-post.php?lang=de [L,QSA]
RewriteRule ^de/kontakt/?$ contact.php?lang=de [L,QSA]

# Spanish language rewrites
RewriteRule ^es/?$ index.php?lang=es [L,QSA]
RewriteRule ^es/safaris/?$ safaris.php?lang=es [L,QSA]
RewriteRule ^es/kilimanjaro/?$ kilimanjaro.php?lang=es [L,QSA]
RewriteRule ^es/zanzibar/?$ zanzibar.php?lang=es [L,QSA]
RewriteRule ^es/alojamientos/?$ accommodations.php?lang=es [L,QSA]
RewriteRule ^es/sobre-nosotros/?$ about.php?lang=es [L,QSA]
RewriteRule ^es/blog/?$ blog.php?lang=es [L,QSA]
RewriteRule ^es/blog-post/?$ blog-post.php?lang=es [L,QSA]
RewriteRule ^es/contacto/?$ contact.php?lang=es [L,QSA]

# Chinese language rewrites
RewriteRule ^zh/?$ index.php?lang=zh [L,QSA]
RewriteRule ^zh/safaris/?$ safaris.php?lang=zh [L,QSA]
RewriteRule ^zh/kilimanjaro/?$ kilimanjaro.php?lang=zh [L,QSA]
RewriteRule ^zh/zanzibar/?$ zanzibar.php?lang=zh [L,QSA]
RewriteRule ^zh/accommodations/?$ accommodations.php?lang=zh [L,QSA]
RewriteRule ^zh/about/?$ about.php?lang=zh [L,QSA]
RewriteRule ^zh/blog/?$ blog.php?lang=zh [L,QSA]
RewriteRule ^zh/blog-post/?$ blog-post.php?lang=zh [L,QSA]
RewriteRule ^zh/contact/?$ contact.php?lang=zh [L,QSA]

# Turkish language rewrites
RewriteRule ^tr/?$ index.php?lang=tr [L,QSA]
RewriteRule ^tr/safariler/?$ safaris.php?lang=tr [L,QSA]
RewriteRule ^tr/kilimanjaro/?$ kilimanjaro.php?lang=tr [L,QSA]
RewriteRule ^tr/zanzibar/?$ zanzibar.php?lang=tr [L,QSA]
RewriteRule ^tr/konaklamalar/?$ accommodations.php?lang=tr [L,QSA]
RewriteRule ^tr/hakkimizda/?$ about.php?lang=tr [L,QSA]
RewriteRule ^tr/blog/?$ blog.php?lang=tr [L,QSA]
RewriteRule ^tr/blog-yazisi/?$ blog-post.php?lang=tr [L,QSA]
RewriteRule ^tr/iletisim/?$ contact.php?lang=tr [L,QSA]

# Custom 404
ErrorDocument 404 /index.php

# Cache static assets
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/x-icon "access plus 1 year"
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# Gzip compression
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json image/svg+xml text/xml application/xml
</IfModule>
